pipeline {
    agent {
        docker {
            image 'hashicorp/terraform:1.14.7'
            args  '--entrypoint= -u root'
        }
    }

    parameters {
        choice(name: 'ACTION', choices: ['apply', 'destroy'], description: 'Select the action to perform on the infrastructure')
    }

    environment {
        AWS_ACCESS_KEY_ID     = credentials('AWS_ACCESS_KEY_ID')
        AWS_SECRET_ACCESS_KEY = credentials('AWS_SECRET_ACCESS_KEY')
        AWS_DEFAULT_REGION    = 'ap-south-1'
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Setup Checkov') {
            steps {
                sh '''
                    apk add --no-cache python3 py3-pip
                    pip3 install checkov --quiet
                '''
            }
        }

        stage('Checkov IaC Scan') {
            steps {
                catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                    sh '''
                        checkov -d Terraform \
                                --hard-fail-on CRITICAL \
                                --output cli \
                                --quiet
                    '''
                }
            }
        }

        stage('Terraform Init') {
            steps {
                dir('Terraform') {
                    sh 'terraform init'
                }
            }
        }

        stage('Terraform FMT') {
            steps {
                dir('Terraform') {
                    catchError(buildResult: 'UNSTABLE', stageResult: 'UNSTABLE') {
                        sh 'terraform fmt -check'
                    }
                }
            }
        }

        stage('Terraform Validate') {
            steps {
                dir('Terraform') {
                    sh 'terraform validate'
                }
            }
        }

        stage('Terraform Plan') {
            steps {
                dir('Terraform') {
                    script {
                        if (params.ACTION == 'destroy') {
                            sh 'terraform plan -destroy'
                        } else {
                            sh 'terraform plan -out=tfplan'
                        }
                    }
                }
            }
        }

        stage('Manual Approval') {
            agent none
            steps {
                input message: "Are you sure you want to ${params.ACTION} the resources?",
                      ok: "Proceed with ${params.ACTION}"
            }
        }

        stage('Terraform Action') {
            steps {
                dir('Terraform') {
                    script {
                        if (params.ACTION == 'destroy') {
                            sh 'terraform destroy -auto-approve'
                        } else {
                            sh 'terraform apply -auto-approve'
                        }
                    }
                }
            }
        }

    }

    post {
        success {
            echo "Terraform ${params.ACTION} completed successfully."
        }
        unstable {
            echo 'Pipeline completed with warnings - review Checkov or FMT results.'
        }
        failure {
            echo 'Pipeline failed - check stage logs above.'
        }
    }
}
